{
    "ts-node": {
      "transpileOnly": true
    },
    "compilerOptions": {
      "outDir": "lib",
      "declaration": true,
      "declarationMap": true,
      "module": "commonjs",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "target": "ES2020",
      "noImplicitAny": true,
      "moduleResolution": "node",
      "resolveJsonModule": true,
      "sourceMap": true,
      "baseUrl": ".",
      "strict": true,
      "allowJs": true,
      "skipLibCheck": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules/*"]
  }