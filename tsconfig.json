{
  "extends": "@open-web3/dev-config/config/tsconfig.json",
  "exclude": [
    "packages-evm/*",
    "build/**/*",
    "**/build/**/*"
  ],
  "compilerOptions": {
    "target": "es2019",
    "module": "CommonJS",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "paths": {
      "@selendra/types": [
        "packages/types/src"
      ],
      "@selendra/types/*": [
        "packages/types/src/*"
      ],
      "@selendra/type-definitions": [
        "packages/type-definitions/src"
      ],
      "@selendra/type-definitions/*": [
        "packages/type-definitions/src/*"
      ],
    },
    "skipLibCheck": true,
    "typeRoots": [
      "./node_modules/@polkadot/ts",
      "./node_modules/@types"
    ]
  }
}
