{
    "compilerOptions": {
      "target": "es2019",
      "module": "CommonJS",
      "baseUrl": ".",
      "resolveJsonModule": true,
      "paths": {
        "@selendra/type-definitions/*": [
          "packages/type-definitions/src/*"
        ],
        "@selendra/types/*": [
            "packages/types/src/*"
        ],
        "@selendra/eth-transactions/*": [
          "packages/eth-transactions/src/*"
      ],
      },
      "skipLibCheck": true,
      "typeRoots": [
        "./node_modules/@polkadot/ts",
        "./node_modules/@types"
      ]
    }
  }  